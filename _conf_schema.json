        "default": 2
      }
    }
  },
  "delivery_settings": {
    "description": "📨 发送限制",
    "type": "object",
    "items": {
      "max_unanswered": {
        "description": "未回复阈值",
        "type": "int",
        "hint": "连续未获回复达到此次数后暂停主动消息。",
        "default": 3
      },
      "sleep_exception_probability": {
        "description": "睡眠异常概率",
        "type": "float",
        "hint": "每个会话每天在睡眠中触发一次异常主动消息的概率，范围 0-1。",
        "default": 0.08
      },
      "minimum_idle_for_window_minutes": {
        "description": "窗口最短沉默",
        "type": "int",
        "hint": "日程窗口触发前要求的最短会话空闲时间，单位为分钟。",
        "default": 20
      },
      "proactive_window_jitter_minutes": {
        "description": "主动窗口随机偏移",
        "type": "int",
        "hint": "日程主动窗口在计划时间前后随机偏移的分钟数，范围 0-60；用户委托回访不受影响。",
        "default": 15
      },
      "segmented_reply_settings": {
        "description": "🔪 主动消息分段",
        "type": "object",
        "items": {
          "enable": {
            "description": "启用分段",
            "type": "bool",
            "hint": "将不超过阈值的主动消息拆成多条发送。",
            "default": true
          },
          "words_count_threshold": {
            "description": "不分段字数阈值",
            "type": "int",
            "hint": "原文超过此值时整条发送。",
            "slider": {
              "min": 0,
              "max": 1024,
              "step": 2
            },
            "default": 150
          },
          "split_mode": {
            "description": "分段模式",
            "type": "string",
            "options": [
              "regex",
              "words"
            ],
            "labels": [
              "正则表达式",
              "分段词列表"
            ],
            "default": "words"
          },
          "regex": {
            "description": "分段正则表达式",
            "type": "string",
            "hint": "每次完整匹配作为一个消息段，无效时回退默认规则。",
            "condition": {
              "split_mode": "regex"
            },
            "default": ".*?[。？！~…\\n]+|.+$"
          },
          "split_words": {
            "description": "分段词列表",
            "type": "list",
            "hint": "检测到任意普通文本关键词时分段，并保留关键词；\\n 表示换行。",
            "condition": {
              "split_mode": "words"
            },
            "default": [
              "。",
              "？",
              "！",
              "?",
              "!",
              "~",
              "…",
              "\\n"
            ]
          },
          "enable_content_cleanup": {
            "description": "启用内容清理",
            "type": "bool",
            "hint": "分段后使用正则表达式移除匹配内容。",
            "default": false
          },
          "content_cleanup_rule": {
            "description": "内容清理正则表达式",
            "type": "string",
            "hint": "例如 [\\n] 可移除分段中残留的换行。",
            "condition": {
              "enable_content_cleanup": true
            },
            "default": "[\\n]"
          },
          "interval_method": {
            "description": "间隔计算方法",
            "type": "string",
            "hint": "random 使用随机区间；log 根据中英文字数计算。",
            "options": [
              "random",
              "log"
            ],
            "labels": [
              "随机",
              "对数计算"
            ],
            "default": "log"
          },
          "interval": {
            "description": "随机间隔（秒）",
            "type": "string",
            "hint": "格式为最小值,最大值，例如 0.8,2.0。",
            "condition": {
              "interval_method": "random"
            },
            "default": "0.8,2.0"
          },
          "log_base": {
            "description": "对数底数",
            "type": "string",
            "hint": "必须大于 1。",
            "condition": {
              "interval_method": "log"
            },
            "default": "2.6"
          }
        }
      },
      "recent_chat_messages": {
        "description": "最近聊天条数",
        "type": "int",
        "hint": "生成主动消息时参考的最近会话记录数量。",
        "default": 8
      },
      "proactive_prompt": {
        "description": "主动消息提示词",
        "type": "text",
        "hint": "可使用 {current_time}、{current_state}、{intent}、{unanswered_count}。",
        "default": "你需要以当前人格自然地发起一条主动消息。当前时间：{current_time}。当前状态：{current_state}。触发原因：{intent}。连续未获回应：{unanswered_count} 次。结合会话历史，只输出要发送的消息正文，不要解释任务。"
      }
    }
  },
  "followup_settings": {
    "description": "⏰ 回访",
    "type": "object",
    "items": {
      "enable": {
        "description": "启用回访工具",
        "type": "bool",
        "hint": "允许模型在用户明确委托时创建定时回访。",
        "default": true
      },
      "misfire_grace_minutes": {
        "description": "补发容忍窗口",
        "type": "int",
        "hint": "插件重启后仍允许补发的最大延迟，单位为分钟。",
        "default": 30
      },
      "max_pending_per_session": {
        "description": "会话待回访上限",
        "type": "int",
        "hint": "单个会话同时保留的回访任务最大数量。",
        "default": 10
      }
    }
  }
}
