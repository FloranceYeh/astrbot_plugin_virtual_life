      },
      "daily_budget_max": {
        "description": "日预算上限",
        "type": "int",
        "hint": "每天随机主动消息额度的上限。",
        "default": 1
      },
      "llm_bonus_max": {
        "description": "LLM 额外预算",
        "type": "int",
